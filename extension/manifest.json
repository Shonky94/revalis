{
  "manifest_version": 3,
  "name": "ContextSnap",
  "version": "1.0",
  "description": "Highlight text to get contextual AI explanations.",
  "permissions": ["scripting", "activeTab", "tabs", "storage", "clipboardWrite", "contextMenus"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "ContextSnap"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["sidebar.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
